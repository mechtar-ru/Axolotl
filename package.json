{
  "name": "axolotl",
  "version": "1.0.0",
  "description": "Visual AI-Agent Orchestration Platform",
  "private": true,
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "cd backend && mvn spring-boot:run",
    "dev:frontend": "cd frontend && ELECTRON=true npm run electron:dev",
    "build": "cd frontend && npm run electron:build",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && mvn package -DskipTests",
    "test": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd backend && mvn test",
    "test:frontend": "cd frontend && npm run test:unit",
    "lint": "cd frontend && npm run type-check",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0",
    "java": "^21"
  }
}
