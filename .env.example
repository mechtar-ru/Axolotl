# Backend
# DB path — absolute path, or leave empty for default (~/.axolotl/schema.db)
AXOLOTL_DB_PATH=
AXOLOTL_JWT_SECRET=axolotl-secret-key-must-be-at-least-32-chars-long-for-hs256
SPRING_PROFILE=docker
POSTGRES_DB=axolotl
POSTGRES_USER=axolotl
POSTGRES_PASSWORD=your-password-here

# MemPalace
MEMPALACE_URL=http://mempalace:8765

# Frontend
VITE_API_URL=http://localhost:8080/api
VITE_WS_URL=ws://localhost:8080/ws

# JWT (для будущей аутентификации)
JWT_SECRET=change-me
JWT_EXPIRATION=86400000
