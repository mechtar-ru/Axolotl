<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <property name="LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- JSON appender for ELK/Loki -->
    <appender name="JSON" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <includeMarker>axolotl</includeMarker>
            <provider class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
                <providers>
                    <timestamp>
                        <fieldName>timestamp</fieldName>
                        <pattern>yyyy-MM-dd'T'HH:mm:ss.SSSZ</pattern>
                    </timestamp>
                    <log Level>
                        <fieldName>level</fieldName>
                    </log Level>
                    <logger>
                        <fieldName>logger</fieldName>
                    </logger>
                    <message>
                        <fieldName>message</fieldName>
                        <fieldName>message</fieldName>
                    </message>
                    <stackTrace>
                        <fieldName>stacktrace</fieldName>
                    </stackTrace>
                    <mdc/>
                    <marker>
                        <fieldName>marker</fieldName>
                    </marker>
                </providers>
            </encoder>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/axolotl.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/axolotl.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxHistory>30</maxHistory>
            <timeBasedFileNamingAndTriggeringPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedFNATP">
                <maxFileSize>100MB</maxFileSize>
            </timeBasedFileNamingAndTriggeringPolicy>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- Standard console logging -->
    <logger name="com.agent.orchestrator" level="DEBUG"/>
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.web" level="DEBUG"/>
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <!-- Use CONSOLE for development, JSON for production (set system property) -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <!-- Uncomment for ELK/Loki: -->
        <!-- <appender-ref ref="JSON"/> -->
        <appender-ref ref="FILE"/>
    </root>
</configuration>
