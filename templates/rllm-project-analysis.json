{
  "id": "tpl-rllm-project-analysis",
  "name": "RLLM Project Analysis",
  "description": "Analyze project test folders using Transform nodes for field-based routing",
  "version": "2.0",
  "defaultModel": "rlm",
  "metadata": {
    "template": true,
    "category": "analysis",
    "tags": ["rllm", "analysis", "refactoring", "transform-nodes"],
    "variant": "project-analysis-v2"
  },
  "nodes": [
    {
      "id": "src-1",
      "type": "source",
      "name": "Analysis Request",
      "position": { "x": 100, "y": 200 },
      "data": {
        "sourceData": "Target folders to analyze: backend-next/src/main/java, frontend-next/src. Leave empty for full analysis."
      }
    },
    {
      "id": "agent-1",
      "type": "agent",
      "name": "Project Analyzer",
      "position": { "x": 350, "y": 200 },
      "data": {
        "systemPrompt": "You are a Senior Software Architect using RLLM (Recursive Language Model) for structured project analysis.\n\n## Context\n**Project:** Axolotl - Visual AI Agent Orchestrator\n**Analysis Target:** Test folders - backend-next and frontend-next\n**Production Code:** backend/src/main/java, frontend/src\n\n## RLLM Signature\nUse this signature for structured output:\n```\ncodebase_analysis -> implementation_plan:str, db_changes:str, dependency_rework:str, summary:str\n```\n\nReturn JSON with all 4 fields.",
        "userPrompt": "Analyze backend-next/src/main/java and frontend-next/src. Compare with production code in backend/src and frontend/src. Categorize into: implementation_plan, db_changes, dependency_rework, summary.",
        "model": "rlm",
        "config": {
          "tools": ["directory_read", "file_read", "grep", "git", "graph_query", "memory_write", "bash"],
          "signature": "codebase_analysis -> implementation_plan:str, db_changes:str, dependency_rework:str, summary:str"
        }
      }
    },
    {
      "id": "transform-summary",
      "type": "transform",
      "name": "Extract Summary",
      "position": { "x": 600, "y": 150 },
      "data": {
        "transforms": [{"type": "jsonField", "config": {"field": "summary"}}],
        "routes": [{"condition": "not empty", "targetNodeId": "out-1"}],
        "fallbackValue": "No summary"
      }
    },
    {
      "id": "transform-db",
      "type": "transform",
      "name": "Extract DB Changes",
      "position": { "x": 600, "y": 280 },
      "data": {
        "transforms": [{"type": "jsonField", "config": {"field": "db_changes"}}],
        "routes": [{"condition": "not empty", "targetNodeId": "out-2"}],
        "fallbackValue": "No DB changes"
      }
    },
    {
      "id": "transform-deps",
      "type": "transform",
      "name": "Extract Dependencies",
      "position": { "x": 600, "y": 410 },
      "data": {
        "transforms": [{"type": "jsonField", "config": {"field": "dependency_rework"}}],
        "routes": [{"condition": "not empty", "targetNodeId": "out-3"}],
        "fallbackValue": "No dependency changes"
      }
    },
    {
      "id": "out-1",
      "type": "output",
      "name": "Implementation Summary",
      "position": { "x": 850, "y": 150 },
      "data": {
        "sourceData": "Summary of implemented changes in test folders"
      }
    },
    {
      "id": "out-2",
      "type": "output",
      "name": "Pending DB Changes",
      "position": { "x": 850, "y": 280 },
      "data": {
        "sourceData": "DB schema changes to review later (NOT implemented)"
      }
    },
    {
      "id": "out-3",
      "type": "output",
      "name": "Dependency Report",
      "position": { "x": 850, "y": 410 },
      "data": {
        "sourceData": "Dependencies requiring rework with impact analysis"
      }
    }
  ],
  "edges": [
    { "id": "e1", "source": "src-1", "target": "agent-1", "type": "data" },
    { "id": "e2", "source": "agent-1", "target": "transform-summary", "type": "data" },
    { "id": "e3", "source": "agent-1", "target": "transform-db", "type": "data" },
    { "id": "e4", "source": "agent-1", "target": "transform-deps", "type": "data" },
    { "id": "e5", "source": "transform-summary", "sourcePort": "not empty", "target": "out-1", "type": "data" },
    { "id": "e6", "source": "transform-db", "sourcePort": "not empty", "target": "out-2", "type": "data" },
    { "id": "e7", "source": "transform-deps", "sourcePort": "not empty", "target": "out-3", "type": "data" }
  ]
}